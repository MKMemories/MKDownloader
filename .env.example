# Mot de passe d'accès (fortement recommandé si l'app est exposée sur Internet).
# Laissez vide pour un usage local sans mot de passe.
APP_PASSWORD=

# Dossier de stockage des fichiers téléchargés.
DOWNLOAD_DIR=./data

# Fichier de cookies (format Netscape) pour les contenus privés FB/Instagram.
COOKIES_FILE=./cookies.txt

# Durée de conservation des fichiers avant purge (minutes).
RETENTION_MINUTES=180

# Nombre maximum de téléchargements simultanés.
MAX_CONCURRENT_JOBS=3

# Alternative au fichier : contenu intégral du cookies.txt collé dans une
# variable d'environnement (pratique en cloud, ex. secret Hugging Face).
# COOKIES_CONTENT=
