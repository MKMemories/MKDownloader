<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/player_bg"
    android:orientation="vertical">

    <!-- Hero : bandeau de marque, cohérent avec la page recherche (masqué en plein écran). -->
    <ImageView
        android:id="@+id/heroBanner"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:contentDescription="@string/app_name"
        android:scaleType="centerCrop" />

    <!-- Cadre vidéo premium (hauteur ajustée en 16:9 en portrait, plein écran en paysage) -->
    <FrameLayout
        android:id="@+id/videoContainer"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#000000">

        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:hide_on_touch="true"
            app:resize_mode="fit"
            app:show_buffering="always"
            app:use_controller="true" />

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/scrim_top"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            android:paddingTop="4dp"
            android:paddingBottom="14dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/closeButton"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/close"
                app:icon="@android:drawable/ic_menu_close_clear_cancel"
                app:iconTint="#FFFFFF" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/speedButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp"
                android:text="1×"
                android:textColor="#FFFFFF"
                android:contentDescription="@string/speed" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pipButton"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/pip"
                app:icon="@android:drawable/ic_menu_crop"
                app:iconTint="#FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dlnaButton"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/dlna_cast"
                app:icon="@android:drawable/ic_menu_slideshow"
                app:iconTint="#FFFFFF" />

            <androidx.mediarouter.app.MediaRouteButton
                android:id="@+id/castButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fullscreenButton"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="2dp"
            android:contentDescription="@string/fullscreen"
            app:icon="@android:drawable/ic_menu_crop"
            app:iconTint="#FFFFFF" />

        <ProgressBar
            android:id="@+id/playerLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="#FFFFFF"
            android:visibility="gone" />

        <!-- Retour visuel des gestes (±10 s, luminosité, volume) -->
        <TextView
            android:id="@+id/gestureIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/dropdown_bg"
            android:paddingHorizontal="18dp"
            android:paddingVertical="10dp"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Panneau d'options (masqué en plein écran) -->
    <ScrollView
        android:id="@+id/panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="12dp"
        android:scrollbars="none">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/panelTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <!-- Méta premium : chaîne · vues · date -->
            <TextView
                android:id="@+id/panelMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_dim"
                android:textSize="13sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/qualityButton"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:icon="@android:drawable/ic_menu_manage"
                    android:text="@string/quality_max" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/downloadButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:icon="@android:drawable/stat_sys_download_done"
                    android:text="@string/download" />
            </LinearLayout>

            <!-- Ligne d'actions enrichie : MP3, playlist, favori -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mp3Button"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:paddingHorizontal="6dp"
                    app:icon="@android:drawable/ic_lock_silent_mode_off"
                    android:text="@string/player_mp3" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/playlistButton"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:paddingHorizontal="6dp"
                    app:icon="@android:drawable/ic_input_add"
                    android:text="@string/player_playlist" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/favButton"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minWidth="0dp"
                    android:paddingHorizontal="6dp"
                    app:icon="@android:drawable/btn_star_big_off"
                    android:text="@string/player_fav" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="18dp"
                android:background="@color/card_hi" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/clip_title"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/clip_hint"
                android:textColor="@color/text_dim"
                android:textSize="12sp" />

            <com.google.android.material.slider.RangeSlider
                android:id="@+id/clipRange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:enabled="false"
                android:stepSize="1"
                android:valueFrom="0"
                android:valueTo="100"
                app:thumbColor="@color/accent2"
                app:trackColorActive="@color/accent2" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/clipStart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0:00"
                    android:textColor="@color/text_dim"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/clipEnd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/text_dim"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/downloadClipButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:enabled="false"
                app:icon="@android:drawable/ic_menu_save"
                android:text="@string/download_clip" />

            <!-- Description de la vidéo (repliable) -->
            <View
                android:id="@+id/descDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="18dp"
                android:background="@color/card_hi"
                android:visibility="gone" />

            <TextView
                android:id="@+id/descHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/player_description"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/descBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:autoLink="web"
                android:ellipsize="end"
                android:maxLines="5"
                android:lineSpacingMultiplier="1.15"
                android:textColor="@color/text_dim"
                android:textColorLink="@color/accent2"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/descToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:paddingVertical="4dp"
                android:text="@string/see_more"
                android:textColor="@color/accent2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </ScrollView>
</LinearLayout>
