<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/card"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <FrameLayout
            android:layout_width="104dp"
            android:layout_height="58dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/resultThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/bg"
                android:contentDescription="@string/thumb_desc"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ThumbRounded" />

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:alpha="0.92"
                android:contentDescription="@string/play"
                android:src="@android:drawable/ic_media_play"
                app:tint="#FFFFFF" />

            <!-- Badge de source (YouTube / TikTok / Instagram…). -->
            <TextView
                android:id="@+id/resultSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="3dp"
                android:background="@drawable/source_badge"
                android:paddingHorizontal="5dp"
                android:paddingVertical="1dp"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/resultTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/text"
                android:textSize="14sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.05" />

            <TextView
                android:id="@+id/resultMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_dim"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/favButton"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:contentDescription="@string/favorite"
            app:icon="@android:drawable/btn_star_big_off"
            app:iconSize="20dp"
            app:iconTint="@color/accent2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/moreButton"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:contentDescription="@string/more"
            app:icon="@android:drawable/ic_menu_more"
            app:iconSize="20dp"
            app:iconTint="@color/text_dim" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
